<?xml version="1.0" encoding="utf-8"?>
<!-- Coverage settings for the XPlat collector path. Applied by the backend
     test wrapper when invoked with the coverage flag:
       node scripts/run-dotnet-test.mjs (plus coverage flag)
     Kept in a separate file so iteration runs skip instrumentation. -->
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <Exclude>[*.Tests]*,[*.UnitTests]*,[*.IntegrationTests]*</Exclude>
          <ExcludeByAttribute>GeneratedCodeAttribute,CompilerGeneratedAttribute</ExcludeByAttribute>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
