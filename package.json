{
  "name": "vueapp1-root",
  "private": true,
  "workspaces": [
    "vueapp1.client"
  ],
  "engines": {
    "node": "^22.13.0 || >=24.0.0"
  },
  "scripts": {
    "dev:client": "npm --prefix vueapp1.client run dev",
    "dev:server": "dotnet run --project VueApp1.Server --launch-profile https",
    "build": "dotnet build && npm --prefix vueapp1.client run build",
    "test": "node scripts/run-vitest.mjs && node scripts/run-dotnet-test.mjs --no-build",
    "test:load": "node scripts/load-test.mjs",
    "lint": "npm --prefix vueapp1.client run lint",
    "lint:check": "npm --prefix vueapp1.client run lint:check",
    "format": "npm --prefix vueapp1.client run format",
    "format:check": "npm --prefix vueapp1.client run format:check",
    "type-check": "npm --prefix vueapp1.client run type-check",
    "openapi:sync": "node scripts/openapi-contract.mjs --write",
    "openapi:check": "node scripts/openapi-contract.mjs --check",
    "check": "npm --prefix vueapp1.client run check && dotnet build && npm run openapi:check && node scripts/run-dotnet-test.mjs --no-build",
    "test:backend": "node scripts/run-dotnet-test.mjs",
    "install-githooks": "git config core.hooksPath .githooks",
    "setup": "npm run install-githooks && npm ci && npm --prefix vueapp1.client run rebuild-trusted && dotnet restore --locked-mode && dotnet tool restore",
    "build-server-shutdown": "dotnet build-server shutdown",
    "skills:sync": "node -e \"const fs=require('node:fs');fs.rmSync('.agents/skills',{recursive:true,force:true});fs.cpSync('.claude/skills','.agents/skills',{recursive:true});console.log('Mirrored .claude/skills -> .agents/skills');\"",
    "test:frontend": "node scripts/run-vitest.mjs",
    "check:fast": "npm --prefix vueapp1.client run check:fast && dotnet build && npm run openapi:check && node scripts/run-dotnet-test.mjs --no-build"
  }
}
