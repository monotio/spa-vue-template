{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Performance": {
    "OutputCache": {
      "DefaultExpirationSeconds": 30,
      "ReadExpirationSeconds": 30,
      "SizeLimitBytes": 67108864,
      "MaximumBodySizeBytes": 4194304
    },
    "RateLimiting": {
      "PermitLimit": 5000,
      "QueueLimit": 100,
      "WindowSeconds": 60
    },
    "RequestTimeout": {
      "Enabled": false,
      "DefaultTimeoutSeconds": 10,
      "LongRunningTimeoutSeconds": 30
    }
  },
  "OpenTelemetry": {
    "Enabled": false,
    "Otlp": {
      "Endpoint": ""
    }
  },
  "OpenApi": {
    "Enabled": false
  },
  "Mcp": {
    "Enabled": false
  },
  "Agent": {
    "Enabled": false,
    "Provider": "anthropic",
    "Anthropic": { "Model": "claude-sonnet-4-5" },
    "OpenAI": { "Model": "gpt-5.2" },
    "Pricing": {
      "claude-sonnet-4-5": { "InputPerMTokUsd": 3.0, "CachedInputPerMTokUsd": 0.3, "OutputPerMTokUsd": 15.0 },
      "gpt-5.2": { "InputPerMTokUsd": 1.25, "CachedInputPerMTokUsd": 0.125, "OutputPerMTokUsd": 10.0 }
    },
    "MaxTurnsPerRequest": 10,
    "MaxConsecutiveToolErrors": 3,
    "MaxRequestUsd": 0.5,
    "DailyUsdBudget": 25,
    "RequireApprovalForWrites": true
  },
  "PublicUri": {
    "BaseUri": "https://localhost:7191"
  },
  "AllowedHosts": "*"
}
