# Do not run package lifecycle scripts on install. Install scripts are the
# dominant npm supply-chain attack vector (Shai-Hulud worm, Sep 2025: 1700+
# compromised package versions executing on install). Packages that genuinely
# need their install scripts are rebuilt explicitly via the "rebuild-trusted"
# script in vueapp1.client/package.json — run it after npm ci / after adding
# such a package.
# Trade-off: `npm install <pkg>` will silently skip a legitimate postinstall;
# if a new dependency needs one, add it to rebuild-trusted.
# (npm workspaces: this root .npmrc is the only one — npm ignores .npmrc
# files inside workspace directories.)
ignore-scripts=true
