{
  "permissions": {
    "allow": [
      "Bash(npm run check)",
      "Bash(npm run check:fast)",
      "Bash(npm run build)",
      "Bash(npm run test)",
      "Bash(npm run test:frontend:*)",
      "Bash(npm run test:backend:*)",
      "Bash(npm run lint)",
      "Bash(npm run lint:check)",
      "Bash(npm run format)",
      "Bash(npm run format:check)",
      "Bash(npm run type-check)",
      "Bash(npm run openapi:check)",
      "Bash(npm run openapi:sync)",
      "Bash(npm run build-server-shutdown)",
      "Bash(npm --prefix vueapp1.client run test:*)",
      "Bash(npm --prefix vueapp1.client run lint:*)",
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet restore:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh run view:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); cmd=$(echo \"$input\" | jq -r '.tool_input.command // empty'); if echo \"$cmd\" | grep -qE 'git push.*\\b(master|main)\\b'; then echo 'Direct push to master/main is blocked — use a feature branch + PR.' >&2; exit 2; fi; exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); file=$(echo \"$input\" | jq -r '.tool_input.file_path // empty'); case \"$file\" in */vueapp1.client/*.ts|*/vueapp1.client/*.vue|*/vueapp1.client/*.mts) cd \"$(dirname \"$file\")\" && npx eslint --fix \"$file\" >/dev/null 2>&1 || true ;; esac; exit 0"
          }
        ]
      }
    ]
  }
}
