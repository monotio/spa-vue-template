<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Single explicit source + a catch-all source mapping: if a private feed is ever
         added, packages must be explicitly mapped to it, which blocks dependency-confusion
         attacks (a public package shadowing an internal name) by default. -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
