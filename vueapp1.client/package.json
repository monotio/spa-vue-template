{
  "name": "vueapp1.client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^22.13.0 || >=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --cache --write .",
    "format:check": "prettier --cache --check .",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "check": "npm run lint:check && npm run format:check && npm run type-check && npm run test",
    "test:ci": "vitest run --coverage --reporter=junit --reporter=default --reporter=github-actions --outputFile=test-results/vitest-results.xml",
    "rebuild-trusted": "npm rebuild --ignore-scripts=false fsevents sharp",
    "generate-pwa-assets": "pwa-assets-generator --preset minimal-2023 public/logo.svg",
    "check:fast": "run-p lint:check format:check type-check test"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.1",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "~10.9.2",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.4"
  }
}
